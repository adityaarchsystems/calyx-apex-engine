{
  "name": "cpm-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
    "workspaces": [
        "apps/*",
        "!apps/api-sync-worker",
        "!apps/web-canvas",
        "packages/*"
    ],
  "scripts": {
    "dev": "dotenv -- turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "packageManager": "pnpm@9.15.2",
  "dependencies": {
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.1",
      "@types/react-dom": "^18.3.1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1"
  }
}