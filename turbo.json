{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "build/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "GITHUB_PAT",
    "DAILYDEV_API_TOKEN",
    "DAILYDEV_USERNAME",
    "GOOGLE_DEV_URL",
    "HF_TOKEN",
    "HF_USERNAME",
    "GCP_SERVICE_ACCOUNT_JSON"
  ]
}